PORT=8787
PYTHON_BIN=python
PYTHON_BRIDGE_ENABLED=true
REKORDBOX_POLL_MS=500
HISTORY_OFFSET_SECONDS=60

# Optional:
# REKORDBOX_DB_PATH=C:\Users\<you>\AppData\Roaming\Pioneer\rekordbox\master.db
# REKORDBOX_DB_DIR=C:\Users\<you>\AppData\Roaming\Pioneer\rekordbox
# REKORDBOX_DB_KEY=<sqlcipher-key>

# Ableton Link
ABLETON_LINK_ENABLED=false
ABLETON_LINK_MODULE=@ktamas77/abletonlink
ABLETON_LINK_INITIAL_TEMPO=120

# Rekordbox Hook UDP (from injected rb_hook.dll)
HOOK_UDP_ENABLED=true
HOOK_UDP_PORT=22346
